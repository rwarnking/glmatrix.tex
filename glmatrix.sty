                    \xintifForLast{%
                        \xintifForFirst{}{&}
                        \FPifeq{#1}{0}
                            \roundScalar{##2}
                            \scalarRoundResult
                        \else
                            \numToFractionA{##2}
                        \fi
                        \\
                    }{%
                        \xintifForFirst{}{&}
                        \FPifeq{#1}{0}
                            \roundScalar{##2}
                            \scalarRoundResult
                        \else
                            \numToFractionA{##2}
                        \fi
                    }
