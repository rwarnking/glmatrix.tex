                \FPiflt{##2}{\vecLength}
                    \setScalar{tmp}{\xintNthElt{##1}{#2}}
                \else
                    \setScalar{tmp}{1}
                \fi
                \FPifeq{##1}{##2}
                \else
                    \setScalar{tmp}{0}
                \fi
                \xintifForFirst{%
                    \newVec{matRow}{\tmp}
                }{%
                    \appendToVec{matRow}{\matRow}{\tmp}
                }
            }
            \appendRowToMat{#1}{\csname #1\endcsname}{\matRow}
